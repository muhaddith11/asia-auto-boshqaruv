# ─── Supabase ────────────────────────────────────────────────────────────────
# Loyiha URL va kalitlar (Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server tomon (faqat backend route'larda ishlatiladi, brauzerga chiqmaydi)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Telegram bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
ADMIN_TELEGRAM_ID=123456789
# Buyurtma "tayyor" (tulanmagan) bo'lganda xabar yuboriladigan guruh
# Chat ID (masalan: -1001234567890) yoki @username
TELEGRAM_GROUP_ID=-1001234567890
# Ixtiyoriy: guruh ichidagi mavzu (topic) ID — faqat "Topics" yoqilgan guruhlar uchun
TELEGRAM_GROUP_THREAD_ID=1737
# Bot pollerini avtomatik ishga tushirish (1 = ha)
START_POLLER=0

# ─── SMS (Eskiz.uz) ──────────────────────────────────────────────────────────
ESKIZ_EMAIL=you@example.com
ESKIZ_PASSWORD=your-eskiz-password

# ─── Ilova ───────────────────────────────────────────────────────────────────
# API bazaviy yo'l (odatda /api)
NEXT_PUBLIC_API_BASE=/api
# Saytning to'liq manzili (bot/webhook uchun)
NEXT_PUBLIC_SITE_URL=https://example.com
